results = pandas.DataFrame()

for i in range(1,26):
    clf = DecisionTreeClassifier(max_depth=i)
    result = cross_val_score(clf, X, y, cv=10)
    #print(result)
    #print(sum(result)/len(result))
    results[i] = result
print(results)

results.plot(kind="box")
